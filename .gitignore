# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.turbo/

# 源码目录下的 TS 编译产物（应只在 dist/ 下，防止误生成）
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts.map

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
apps/server/logs/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/

# Temporary files
tmp/
temp/

# uploads - 默认忽略上传文件（如需入库，注释掉此行或改为 !uploads/.gitkeep）
uploads/

# Database backups（本地临时数据，不进版本库）
apps/server/backups/
*.sql.bak