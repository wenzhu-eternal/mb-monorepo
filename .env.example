# Database
POSTGRES_USER=mb_user
POSTGRES_PASSWORD=mb_password
POSTGRES_DB=mb_database
DATABASE_URL=postgresql://mb_user:mb_password@localhost:5432/mb_database

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# API
NODE_ENV=development
API_PORT=3000
API_PREFIX=/api/v1

# CORS
ALLOW_ORIGIN=http://localhost:5173,http://localhost:3000

# Mail (optional)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=noreply@example.com

# WeApp (optional)
WEAPP_APPID=your-weapp-appid
WEAPP_SECRET=your-weapp-secret

# Frontend
VITE_API_BASE_URL=http://localhost:3000
