# Database (required)
POSTGRES_USER=monoforge_user
POSTGRES_PASSWORD=monoforge_password
POSTGRES_DB=monoforge_database
DATABASE_URL=postgresql://monoforge_user:monoforge_password@localhost:5434/monoforge_database

# Redis (optional)
REDIS_URL=redis://localhost:6381

# JWT (required, min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-32chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-32chars

# API
NODE_ENV=development
API_PORT=9000
API_PREFIX=/api/v1
# 应用名（Swagger 标题、邮件主题、邮件模板均引用，新项目通过此变量配置）
APP_NAME=MonoForge

# CORS
ALLOW_ORIGIN=http://localhost:3000,http://localhost:5173

# Cookie
COOKIE_SECURE=false

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Seed (optional；首次部署 pnpm db:seed 时使用，默认密码 888888 首次登录后请立即修改)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=888888
SEED_ADMIN_NICKNAME=Administrator

# Mail (optional)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=noreply@example.com

# WeApp (optional)
WEAPP_APPID=your-weapp-appid
WEAPP_SECRET=your-weapp-secret

# WeChat OAuth (optional)
WECHAT_REDIRECT_URI=https://your-domain.com/auth/wechat/callback

# Docker Build (optional; 仅构建镜像时需要代理才配置)
BUILD_HTTP_PROXY=http://host.docker.internal:7897

# Frontend
VITE_API_BASE_URL=http://localhost:9000
# 品牌名（侧边栏 Logo、页面标题等），新项目接入时修改
VITE_APP_NAME=MonoForge
VITE_APP_SHORT_NAME=MF

# Database Backup (optional; 本机无 pg_dump 时用 Docker 容器内的)
# 恢复请用 pnpm db:restore（psql 原生格式，不要用 Navicat 执行）
BACKUP_CMD=docker exec monoforge-postgres pg_dump -U monoforge_user monoforge_database > "{filepath}"
